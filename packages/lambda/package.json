{
  "name": "@short-as/lambda",
  "version": "0.0.1",
  "scripts": {
    "build:llrt-tests": "esbuild test/llrt/*.test.ts test/shared/*.test.ts --outdir=test/llrt/dist --platform=node --target=es2020 --format=esm --bundle --external:@aws-sdk --external:uuid",
    "test:integration": "sh test/integration/run.sh",
    "test": "npm run test:llrt && npm run test:node",
    "test:llrt": "npm run build:llrt-tests && IS_LOCAL=true .llrt/llrt test -d test/llrt/dist",
    "test:node": "IS_LOCAL=true jest",
    "install-llrt-test-runner-mac": "mkdir -p .llrt && curl -L https://github.com/awslabs/llrt/releases/latest/download/llrt-darwin-x64-full-sdk.zip -o .llrt/llrt.zip && unzip -o .llrt/llrt.zip -d .llrt",
    "install-llrt-test-runner-mac-arm": "mkdir -p .llrt && curl -L https://github.com/awslabs/llrt/releases/latest/download/llrt-darwin-arm64-full-sdk.zip -o .llrt/llrt.zip && unzip -o .llrt/llrt.zip -d .llrt",
    "install-llrt-test-runner-linux": "mkdir -p .llrt && curl -L https://github.com/awslabs/llrt/releases/latest/download/llrt-linux-x64-full-sdk.zip -o .llrt/llrt.zip && unzip -o .llrt/llrt.zip -d .llrt"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.651.1",
    "@aws-sdk/client-dynamodb": "^3.525.0",
    "@aws-sdk/client-firehose": "^3.859.0",
    "@aws-sdk/client-s3": "^3.509.0",
    "@aws-sdk/client-ssm": "^3.716.0",
    "@aws-sdk/lib-dynamodb": "^3.525.0",
    "@middy/http-error-handler": "^6.3.0",
    "@middy/http-router": "^6.3.1",
    "cookie": "^1.0.2",
    "jsrsasign": "^11.1.0",
    "jsrsasign-util": "^1.0.5",
    "ua-parser-js": "^2.0.7"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.149",
    "@types/jest": "^30.0.0",
    "@types/jsrsasign": "^10.5.15",
    "esbuild": "^0.27.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6"
  }
}
